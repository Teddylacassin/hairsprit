# Copiez ce fichier en ".env" et remplissez vos propres valeurs avant de lancer l'app

# Clé secrète utilisée pour signer les sessions (clients + admin). CHANGE-LA en production.
JWT_SECRET=remplace-moi-par-une-chaine-longue-et-aleatoire

# Identifiants du COMPTE ADMIN créé automatiquement au premier démarrage
# (utilisés une seule fois, à la création de la base de données)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-moi-des-le-premier-lancement

# Port du serveur (Render/Railway le définissent automatiquement, sinon 3000 par défaut)
PORT=3000
